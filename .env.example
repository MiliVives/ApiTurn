# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/turnero?schema=public"

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Admin user — sign up normally, then copy your Clerk user ID
# from Clerk Dashboard → Users → click user → copy "User ID" (format: user_xxxx)
ADMIN_CLERK_USER_ID=user_xxxx

# Python Optimizer Service
OPTIMIZER_URL=http://localhost:8000

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=re_...
