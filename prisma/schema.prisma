generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
  WORKER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum UrgencyLevel {
  STANDARD
  PRIORITY
  IMMEDIATE
}

enum NotificationType {
  CONFIRMED
  RESCHEDULED
  CANCELLED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               String         @id // Clerk user ID
  email            String         @unique
  name             String
  role             Role           @default(CLIENT)
  renapaNumber     String?        // Registro Nacional de Productores Apícolas
  producerPriority UrgencyLevel   @default(STANDARD) // admin-assigned priority tier
  appointments     Appointment[]
  notifications    Notification[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Service {
  id           String        @id @default(cuid())
  name         String
  description  String?
  durationMin  Int           // minutes per appointment
  isActive     Boolean       @default(true)
  baseFeeARS       Float?    // base service fee (ARS)
  perKgFeeARS      Float?    // per-kg honey processing fee (ARS)
  drumRentalFeeARS Float?    // per-drum rental fee when producer doesn't bring drums (ARS)
  appointments Appointment[]
  schedules    Schedule[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// Available time blocks for a service (per day-of-week)
model Schedule {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 = Sunday … 6 = Saturday
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isActive  Boolean  @default(true)
}

model Appointment {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  serviceId     String
  service       Service           @relation(fields: [serviceId], references: [id])
  scheduledAt   DateTime          // when the appointment is booked for
  status        AppointmentStatus @default(PENDING)
  queuePosition Int?              // set by the Python optimizer
  notes         String?
  honeyVariety  String?
  quantity           Int?          // total frames (= sum of frame breakdown fields)
  frameCount1Half    Int?          // alzas 1/2
  frameCount3Quarter Int?          // alzas 3/4
  frameCountStd      Int?          // alzas standard
  totalEmptyKg       Float?        // total weight of all empty alzas (optional)
  totalFilledKg      Float?        // total weight of all filled alzas (optional)
  urgencyLevel  UrgencyLevel       @default(STANDARD)
  apiarySource  String?
  loteNumber    String?            // auto-assigned on confirmation, e.g. "0001/26"
  loteDate      DateTime?          // when loteNumber was assigned
  estimatedCostARS Float?          // cost estimate saved at confirmation for admin records
  adminNotes    String?
  notifications Notification[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  appointmentId String?
  appointment   Appointment?     @relation(fields: [appointmentId], references: [id])
  type          NotificationType
  message       String
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now())
}
